{
  "name": "nexlead",
  "version": "0.0.1",
  "private": true,
  "description": "AI destekli müşteri bulma ve web sitesi denetim SaaS platformu",
  "scripts": {
    "dev": "turbo dev",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File scripts/kill-ports.ps1",
    "build": "turbo build",
    "typecheck": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "turbo clean && rimraf node_modules/.cache"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
